# =============================================================
# Environment Variables untuk SMP Negeri 1 Genteng Website
# =============================================================
# Copy file ini menjadi .env dan isi dengan value yang benar
# JANGAN commit file .env ke Git!
# =============================================================

# Supabase Configuration
# Dapatkan dari: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Analytics (Opsional)
# Dapatkan dari: Google Analytics → Admin → Data Streams → Measurement ID
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
